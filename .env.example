# T07GPTcodeDetect v3.0 - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME=T07GPTcodeDetect
APP_VERSION=3.0.0
DEBUG=True
ENVIRONMENT=development

# Secret key for signing tokens (CHANGE IN PRODUCTION!)
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production-use-openssl-rand-hex-32

# ============================================
# DATABASE SETTINGS
# ============================================
# SQLite (development)
DATABASE_URL=sqlite:///./t07gptcodedetect.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://username:password@localhost:5432/t07gptcodedetect

# ============================================
# JWT SETTINGS
# ============================================
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# SECURITY SETTINGS
# ============================================
BCRYPT_ROUNDS=12
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:8000"]

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================
# EMAIL SETTINGS (Optional)
# ============================================
SMTP_ENABLED=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@t07gptcodedetect.com
EMAIL_FROM_NAME=T07GPTcodeDetect

# ============================================
# FILE UPLOAD SETTINGS
# ============================================
MAX_UPLOAD_SIZE=5242880
ALLOWED_EXTENSIONS=[".py",".java",".cpp",".js",".ts"]
UPLOAD_DIR=./uploads

# ============================================
# ML MODELS PATHS
# ============================================
JAVA_MODEL_PATH=models/java-detector-finetuned
PYTHON_MODEL_PATH=models/python-detector-finetuned

# ============================================
# ADMIN SETTINGS
# ============================================
# First admin user credentials (created on first run)
ADMIN_EMAIL=admin@t07.com
ADMIN_PASSWORD=a
ADMIN_USERNAME=admin

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5
